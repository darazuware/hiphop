---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found | HipHop Lyrics" description="お探しのページが見つかりませんでした。">
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">

    <p class="text-[var(--c-gold)] text-xs uppercase tracking-widest mb-6">404</p>
    <h1 class="text-4xl font-bold mb-4">Page Not Found</h1>
    <p class="text-[var(--c-muted)] text-sm mb-10 max-w-sm mx-auto leading-relaxed">
      お探しのページは存在しないか、移動した可能性があります。
    </p>

    <div class="space-y-3 max-w-xs mx-auto">
      <a href="/" class="block p-4 bg-[var(--c-surface)] border border-[var(--c-border)] rounded-lg hover:border-[var(--c-gold)] transition-colors text-sm">
        <span class="text-[var(--c-gold)]">→</span> 曲一覧に戻る
      </a>
      <a href="/slang" class="block p-4 bg-[var(--c-surface)] border border-[var(--c-border)] rounded-lg hover:border-[var(--c-gold)] transition-colors text-sm">
        <span class="text-[var(--c-gold)]">→</span> スラング索引
      </a>
    </div>

  </div>
</Layout>
