---
interface Props {
  eng?: string;
  jpn?: string;
  hasExplanation?: boolean;
  label?: string;
}
const { eng, jpn, hasExplanation = false, label } = Astro.props;
---

<div class="lyrics-block border-l-2 border-[var(--c-gold)] pl-4 my-6">
  {label && (
    <p class="text-[var(--c-gold)] text-xs font-bold uppercase tracking-widest mb-2 opacity-70">{label}</p>
  )}
  <p class="text-[var(--c-text)] text-base leading-relaxed mb-1">
    <slot name="eng">{eng}</slot>
  </p>
  <p class="text-[var(--c-muted)] text-sm leading-relaxed italic">
    <slot name="jpn">{jpn}</slot>
  </p>

  {hasExplanation && (
    <details class="mt-3">
      <summary class="cursor-pointer list-none flex items-center gap-1 text-[var(--c-gold)] text-xs font-semibold select-none w-fit py-1">
        <span class="arrow inline-block transition-transform duration-200">▼</span>
        解説を見る
      </summary>
      <div class="mt-2 p-3 bg-[var(--c-surface)] rounded text-[var(--c-muted-mid)] text-sm leading-relaxed border-l border-[var(--c-gold)]/40">
        <slot name="explanation" />
      </div>
    </details>
  )}
</div>

<style>
  details[open] summary .arrow {
    transform: rotate(180deg);
  }
</style>
